# ComfyUI Installation Path
COMFY_DIR="$HOME/Dev/AI/ComfyUI"

# Conda Environment Name
CONDA_ENV="comfy"

# Python Version (for install script)
PYTHON_VERSION="3.12"

# ComfyUI Server Config
LISTEN_ADDRESS="0.0.0.0"
LISTEN_PORT="8188"

# Log Paths (macOS LaunchAgent)
LOG_DIR="$HOME/Library/Logs/ComfyUI"
LOG_FILE="$LOG_DIR/comfyui.log"
ERROR_LOG_FILE="$LOG_DIR/comfyui-error.log"

# Download Cache Directory
DOWNLOAD_DIR="$HOME/.cache/comfy-downloads"

# CivitAI API Key (optional, for restricted models)
# Get from: civitai.com → Settings → API Keys
CIVITAI_API_KEY=""
